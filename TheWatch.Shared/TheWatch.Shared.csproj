<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0;net10.0-android;net10.0-ios</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <!-- Server-only: ASP.NET Core framework and packages that require it -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Confluent.Kafka" Version="2.*" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.*-*" />
    <PackageReference Include="FirebaseAdmin" Version="3.*" />
    <PackageReference Include="Hangfire.Core" Version="1.8.*" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.*" />
    <!-- Azure managed service alternatives (conditional via configuration) -->
    <PackageReference Include="Microsoft.Azure.SignalR" Version="1.*" />
    <PackageReference Include="Azure.Communication.Sms" Version="1.*" />
    <PackageReference Include="Azure.Communication.Email" Version="1.*" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="2.*" />
    <!-- Google Cloud service integrations (conditional via configuration) -->
    <PackageReference Include="Google.Cloud.Speech.V2" Version="1.*" />
    <PackageReference Include="Google.Cloud.Vision.V1" Version="3.*" />
    <PackageReference Include="Google.Apis.CloudHealthcare.v1" Version="1.*" />
  </ItemGroup>

  <!-- Cross-platform packages (safe for mobile) -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.*-*" />
    <PackageReference Include="Serilog" Version="4.*" />
    <PackageReference Include="Serilog.Enrichers.Environment" Version="3.*" />
    <PackageReference Include="Serilog.Enrichers.Thread" Version="4.*" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.*" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.*" />
  </ItemGroup>
</Project>
