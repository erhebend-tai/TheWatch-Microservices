{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(up{job=~\"thewatch-.*\"} == 1)",
          "legendFormat": "Services Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "green", "value": 12 }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "title": "Request Rate (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_http_requests_total[5m])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_http_requests_total{status_class=\"5xx\"}[5m])) by (service)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(thewatch_http_request_duration_ms_bucket[5m])) by (service, le))",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Incidents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(increase(thewatch_incidents_total[1h]))",
          "legendFormat": "Last Hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Dispatches (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "sum(increase(thewatch_dispatches_total[1h]))",
          "legendFormat": "Dispatches"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Dispatch Response Time (P90)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.90, sum(rate(thewatch_dispatch_response_time_min_bucket[30m])) by (le))",
          "legendFormat": "P90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "min": 0,
          "max": 30,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "Kafka Event Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_kafka_events_total[5m])) by (topic, direction)",
          "legendFormat": "{{ topic }} ({{ direction }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "unit": "evt/s"
        }
      }
    },
    {
      "title": "Health Readings by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_health_readings_total[5m])) by (vital_type)",
          "legendFormat": "{{ vital_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 },
          "unit": "rps"
        }
      }
    },
    {
      "title": "Auth Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_auth_events_total{success=\"true\"}[5m])) by (action)",
          "legendFormat": "{{ action }} (success)"
        },
        {
          "expr": "sum(rate(thewatch_auth_events_total{success=\"false\"}[5m])) by (action)",
          "legendFormat": "{{ action }} (failed)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "evt/s"
        }
      }
    },
    {
      "title": "Mesh Network Messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(thewatch_mesh_messages_total[5m])) by (message_type)",
          "legendFormat": "{{ message_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "unit": "msg/s"
        }
      }
    },
    {
      "title": "Compliance Events",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum(increase(thewatch_compliance_events_total[24h])) by (framework, action)",
          "legendFormat": "{{ framework }}/{{ action }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Database Operation Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(thewatch_db_operation_duration_ms_bucket[5m])) by (service, le))",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Connections (SignalR/WebSocket)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(thewatch_active_connections) by (service)",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["thewatch", "overview", "microservices"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "TheWatch — Platform Overview",
  "uid": "thewatch-overview",
  "version": 1
}
