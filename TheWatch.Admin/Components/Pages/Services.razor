@page "/services"
@attribute [Authorize(Roles = "Admin")]
@inject AdminApiClient Api
@inject NotificationService Notification
@implements IDisposable

<PageTitle>TheWatch — Service Management</PageTitle>

@* ── Header ── *@
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <RadzenIcon Icon="dns" style="font-size: 2rem; color: var(--rz-primary);" />
        <RadzenText TextStyle="TextStyle.H4" class="rz-mb-0">Service Management</RadzenText>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenLabel Text="Auto-refresh (15s)" Component="autoRefreshToggle" />
            <RadzenSwitch @bind-Value="_autoRefreshEnabled" Name="autoRefreshToggle" Change="@OnAutoRefreshToggled" />
        </RadzenStack>
        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                      Click="@RefreshAsync" IsBusy="@_loading" />
    </RadzenStack>
</RadzenStack>

@* ── Summary Cards ── *@
<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-p-4" style="border-left: 4px solid var(--rz-success);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="check_circle" style="font-size: 2.5rem; color: var(--rz-success);" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H3" class="rz-mb-0" style="color: var(--rz-success);">
                        @_services.Count(s => s.Status == "Healthy")
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" style="text-transform: uppercase; letter-spacing: 0.1em;">
                        Healthy Services
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-p-4" style="border-left: 4px solid var(--rz-warning);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="warning" style="font-size: 2.5rem; color: var(--rz-warning);" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H3" class="rz-mb-0" style="color: var(--rz-warning);">
                        @_services.Count(s => s.Status == "Unhealthy")
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" style="text-transform: uppercase; letter-spacing: 0.1em;">
                        Unhealthy Services
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-p-4" style="border-left: 4px solid var(--rz-danger);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="cancel" style="font-size: 2.5rem; color: var(--rz-danger);" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H3" class="rz-mb-0" style="color: var(--rz-danger);">
                        @_services.Count(s => s.Status == "Offline")
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" style="text-transform: uppercase; letter-spacing: 0.1em;">
                        Offline Services
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@* ── Service Grid ── *@
<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">
        <RadzenIcon Icon="grid_view" style="vertical-align: middle;" /> All Services
    </RadzenText>

    <RadzenDataGrid @ref="_grid" Data="@_services" TItem="ServiceHealthInfo"
                    AllowSorting="true" RowClick="@OnRowClick"
                    RowRender="@OnRowRender" Style="cursor: pointer;">

        <Columns>
            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="ID" Width="100px" Sortable="true"
                                  Property="Id">
                <Template Context="svc">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="@svc.Icon" style="font-size: 1.25rem;" />
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0" style="font-weight: 600;">
                            @svc.Id
                        </RadzenText>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Service Name" Width="200px"
                                  Property="Name" Sortable="true" />

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Description" Width="280px"
                                  Property="Description" Sortable="false" />

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Status" Width="130px"
                                  Property="Status" Sortable="true">
                <Template Context="svc">
                    <RadzenBadge BadgeStyle="@GetBadgeStyle(svc.Status)" Text="@(svc.Status ?? "Unknown")"
                                 IsPill="true" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Response (ms)" Width="140px"
                                  Property="ResponseTimeMs" Sortable="true">
                <Template Context="svc">
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0"
                                style="@GetResponseTimeStyle(svc.ResponseTimeMs)">
                        @(svc.ResponseTimeMs.HasValue ? $"{svc.ResponseTimeMs} ms" : "—")
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Base URL" Width="220px"
                                  Property="BaseUrl" Sortable="false">
                <Template Context="svc">
                    <code style="font-size: 0.85em;">@(svc.BaseUrl ?? "N/A")</code>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ServiceHealthInfo" Title="Last Check" Width="180px"
                                  Property="LastCheck" Sortable="true" FormatString="{0:yyyy-MM-dd HH:mm:ss}" />
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@* ── Response Time Chart ── *@
<RadzenCard class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">
        <RadzenIcon Icon="bar_chart" style="vertical-align: middle;" /> Response Times
    </RadzenText>

    <RadzenChart Style="height: 320px;">
        <RadzenColumnSeries Data="@_services.Where(s => s.ResponseTimeMs.HasValue)"
                            CategoryProperty="Id" ValueProperty="ResponseTimeMs"
                            Title="Response Time (ms)" />
        <RadzenCategoryAxis>
            <RadzenAxisTitle Text="Service" />
        </RadzenCategoryAxis>
        <RadzenValueAxis>
            <RadzenAxisTitle Text="ms" />
        </RadzenValueAxis>
        <RadzenColumnOptions Radius="4" />
        <RadzenLegend Visible="false" />
    </RadzenChart>
</RadzenCard>

@* ── Service Detail Panel ── *@
@if (_selectedService is not null)
{
    <RadzenCard class="rz-mb-4" style="border-left: 4px solid var(--rz-primary);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="@_selectedService.Icon" style="font-size: 2rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0">
                    @_selectedService.Id — @_selectedService.Name
                </RadzenText>
                <RadzenBadge BadgeStyle="@GetBadgeStyle(_selectedService.Status)"
                             Text="@(_selectedService.Status ?? "Unknown")" IsPill="true" />
            </RadzenStack>
            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@(() => _selectedService = null)" Variant="Variant.Text" />
        </RadzenStack>

        <RadzenRow Gap="1.5rem">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFieldset Text="Service Information">
                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Service ID:
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">@_selectedService.Id</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Name:
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">@_selectedService.Name</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Description:
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">@_selectedService.Description</RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Response Time:
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">
                                @(_selectedService.ResponseTimeMs.HasValue ? $"{_selectedService.ResponseTimeMs} ms" : "N/A")
                            </RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Endpoint URL:
                            </RadzenText>
                            <code style="font-size: 0.85em;">@(_selectedService.BaseUrl ?? "N/A")/health</code>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Body2" style="font-weight: 600; min-width: 120px;">
                                Last Check:
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">
                                @(_selectedService.LastCheck?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")
                            </RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenFieldset>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFieldset Text="Recent Health Check History">
                    <RadzenDataGrid Data="@_healthHistory" TItem="HealthCheckEntry"
                                    Density="Density.Compact" AllowSorting="false"
                                    Style="max-height: 240px; overflow-y: auto;">
                        <Columns>
                            <RadzenDataGridColumn TItem="HealthCheckEntry" Title="Timestamp" Width="180px"
                                                  Property="Timestamp" FormatString="{0:yyyy-MM-dd HH:mm:ss}" />
                            <RadzenDataGridColumn TItem="HealthCheckEntry" Title="Status" Width="110px"
                                                  Property="Status">
                                <Template Context="entry">
                                    <RadzenBadge BadgeStyle="@GetBadgeStyle(entry.Status)"
                                                 Text="@entry.Status" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="HealthCheckEntry" Title="Response (ms)" Width="120px"
                                                  Property="ResponseMs" />
                        </Columns>
                    </RadzenDataGrid>
                </RadzenFieldset>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
}

@* ── Loading Overlay ── *@
@if (_loading && !_services.Any())
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                 class="rz-mt-12">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-2" style="opacity: 0.6;">
            Loading service health data...
        </RadzenText>
    </RadzenStack>
}

<style>
    ::deep .service-healthy {
        border-left: 3px solid var(--rz-success);
    }

    ::deep .service-unhealthy {
        border-left: 3px solid var(--rz-warning);
        background-color: color-mix(in srgb, var(--rz-warning) 5%, transparent);
    }

    ::deep .service-offline {
        border-left: 3px solid var(--rz-danger);
        background-color: color-mix(in srgb, var(--rz-danger) 5%, transparent);
    }
</style>

@code {
    private List<ServiceHealthInfo> _services = new();
    private ServiceHealthInfo? _selectedService;
    private List<HealthCheckEntry> _healthHistory = new();
    private RadzenDataGrid<ServiceHealthInfo>? _grid;

    private bool _loading;
    private bool _autoRefreshEnabled = true;
    private Timer? _refreshTimer;

    // ── Lifecycle ──

    protected override async Task OnInitializedAsync()
    {
        await LoadServicesAsync();
        StartAutoRefreshTimer();
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }

    // ── Data Loading ──

    private async Task LoadServicesAsync()
    {
        _loading = true;
        try
        {
            _services = await Api.GetAllServiceHealthAsync();
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Service Load Failed",
                $"Could not retrieve service health: {ex.Message}", duration: 6000);
            _services = GetFallbackServices();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        await LoadServicesAsync();

        if (_selectedService is not null)
        {
            _selectedService = _services.FirstOrDefault(s => s.Id == _selectedService.Id);
            if (_selectedService is not null)
                _healthHistory = GenerateMockHistory(_selectedService);
        }

        Notification.Notify(NotificationSeverity.Info, "Refreshed",
            "Service health data updated.", duration: 2000);
    }

    // ── Auto-Refresh Timer ──

    private void StartAutoRefreshTimer()
    {
        _refreshTimer?.Dispose();
        if (_autoRefreshEnabled)
        {
            _refreshTimer = new Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await LoadServicesAsync();

                    if (_selectedService is not null)
                    {
                        _selectedService = _services.FirstOrDefault(s => s.Id == _selectedService.Id);
                        if (_selectedService is not null)
                            _healthHistory = GenerateMockHistory(_selectedService);
                    }

                    StateHasChanged();
                });
            }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
        }
    }

    private void OnAutoRefreshToggled(bool enabled)
    {
        _autoRefreshEnabled = enabled;
        StartAutoRefreshTimer();

        Notification.Notify(
            enabled ? NotificationSeverity.Success : NotificationSeverity.Warning,
            "Auto-Refresh",
            enabled ? "Auto-refresh enabled (15s interval)." : "Auto-refresh disabled.",
            duration: 2000);
    }

    // ── Row Interaction ──

    private void OnRowClick(DataGridRowMouseEventArgs<ServiceHealthInfo> args)
    {
        _selectedService = args.Data;
        _healthHistory = GenerateMockHistory(_selectedService);
    }

    private void OnRowRender(RowRenderEventArgs<ServiceHealthInfo> args)
    {
        args.Attributes.Add("class", args.Data.Status switch
        {
            "Healthy"   => "service-healthy",
            "Unhealthy" => "service-unhealthy",
            "Offline"   => "service-offline",
            _           => string.Empty
        });
    }

    // ── Styling Helpers ──

    private static BadgeStyle GetBadgeStyle(string? status) => status switch
    {
        "Healthy"   => BadgeStyle.Success,
        "Unhealthy" => BadgeStyle.Warning,
        "Offline"   => BadgeStyle.Danger,
        _           => BadgeStyle.Light
    };

    private static string GetResponseTimeStyle(int? ms) => ms switch
    {
        null        => "opacity: 0.4;",
        <= 100      => "color: var(--rz-success); font-weight: 600;",
        <= 300      => "color: var(--rz-warning); font-weight: 600;",
        _           => "color: var(--rz-danger); font-weight: 600;"
    };

    // ── Mock Health History ──

    private static List<HealthCheckEntry> GenerateMockHistory(ServiceHealthInfo service)
    {
        var rng = new Random(service.Id.GetHashCode());
        var now = DateTime.UtcNow;
        var history = new List<HealthCheckEntry>();

        for (int i = 0; i < 10; i++)
        {
            var timestamp = now.AddMinutes(-15 * i);
            var roll = rng.Next(100);
            var status = service.Status == "Offline"
                ? (roll < 80 ? "Offline" : "Unhealthy")
                : service.Status == "Unhealthy"
                    ? (roll < 50 ? "Unhealthy" : "Healthy")
                    : (roll < 90 ? "Healthy" : "Unhealthy");
            var responseMs = status == "Offline"
                ? 0
                : (service.ResponseTimeMs ?? 100) + rng.Next(-40, 60);

            history.Add(new HealthCheckEntry(timestamp, status, Math.Max(0, responseMs)));
        }

        return history;
    }

    // ── Fallback Service Definitions ──

    private static List<ServiceHealthInfo> GetFallbackServices() => new()
    {
        new("P1",  "Core Gateway",      "Central API gateway and service orchestration",          "dns",              "Offline", null,  "http://localhost:5001", null),
        new("P2",  "Voice Emergency",    "Voice-activated emergency SOS and dispatch",             "emergency",        "Offline", null,  "http://localhost:5002", null),
        new("P3",  "Mesh Network",       "Peer-to-peer mesh networking and offline sync",          "cell_tower",       "Offline", null,  "http://localhost:5003", null),
        new("P4",  "Wearable",           "Wearable device integration and biometric tracking",     "watch",            "Offline", null,  "http://localhost:5004", null),
        new("P5",  "Auth & Security",    "Authentication, authorization, and security services",   "shield",           "Offline", null,  "http://localhost:5005", null),
        new("P6",  "First Responder",    "First responder coordination and dispatch",              "local_police",     "Offline", null,  "http://localhost:5006", null),
        new("P7",  "Family Health",      "Family health monitoring and wellness tracking",         "favorite",         "Offline", null,  "http://localhost:5007", null),
        new("P8",  "Disaster Relief",    "Disaster relief coordination and resource management",   "flood",            "Offline", null,  "http://localhost:5008", null),
        new("P9",  "Doctor Services",    "Telemedicine and doctor consultation services",          "medical_services", "Offline", null,  "http://localhost:5009", null),
        new("P10", "Gamification",       "Gamification, achievements, and community engagement",   "trophy",           "Offline", null,  "http://localhost:5010", null),
    };

    // ── Records ──
    // ServiceHealthInfo is defined in TheWatch.Admin.Services (AdminApiClient.cs)
    // and imported via _Imports.razor.

    public record HealthCheckEntry(
        DateTime Timestamp,
        string Status,
        int ResponseMs);
}
