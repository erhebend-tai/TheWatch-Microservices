@page "/forgot-password"
@inject WatchAuthService AuthService
@inject NavigationManager Nav
@inject NotificationService Notification

<div class="page-content" style="display: flex; justify-content: center; align-items: center; min-height: 80vh;">
    <RadzenCard Style="width: 100%; max-width: 400px; padding: 2rem;">
        <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="margin-bottom: 1.5rem;">
            <span class="material-symbols-outlined" style="font-size: 3rem; color: var(--rz-primary);">lock_reset</span>
            <RadzenText TextStyle="TextStyle.H4">Forgot Password</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--watch-muted); text-align: center;">
                Enter your email address and we'll send you a link to reset your password.
            </RadzenText>
        </RadzenStack>

        @if (!_emailSent)
        {
            <RadzenTemplateForm TItem="ForgotPasswordModel" Data="@_model" Submit="@OnSubmit">
                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="Email Address" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.Email" Name="Email" Placeholder="Enter your email" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="Email" Text="Email is required" />
                            <RadzenEmailValidator Component="Email" Text="Invalid email address" />
                        </Helper>
                    </RadzenFormField>
                    
                    <RadzenButton Text="Send Reset Link" ButtonType="ButtonType.Submit"
                                  ButtonStyle="ButtonStyle.Primary" Style="width: 100%;" IsBusy="@_loading" />
                    
                    <RadzenLink Text="Back to Login" Style="text-align: center; display: block;"
                                @onclick="@(() => Nav.NavigateTo("/login"))" />
                </RadzenStack>
            </RadzenTemplateForm>
        }
        else
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <span class="material-symbols-outlined" style="font-size: 2rem; color: var(--rz-success);">mark_email_read</span>
                <RadzenText TextStyle="TextStyle.H6" Style="text-align: center;">
                    Reset Link Sent
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--watch-muted); text-align: center;">
                    We've sent a password reset link to <strong>@_model.Email</strong>. 
                    Please check your email and follow the instructions to reset your password.
                </RadzenText>
                <RadzenButton Text="Back to Login" ButtonStyle="ButtonStyle.Secondary" 
                              Style="width: 100%; margin-top: 1rem;"
                              @onclick="@(() => Nav.NavigateTo("/login"))" />
            </RadzenStack>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Dark"
                         AllowClose="false" Style="margin-top: 0.5rem;">@_error</RadzenAlert>
        }
    </RadzenCard>
</div>

@code {
    private ForgotPasswordModel _model = new();
    private bool _loading;
    private bool _emailSent;
    private string? _error;

    private string P5Url => "http://localhost:5005";

    private async Task OnSubmit()
    {
        _loading = true;
        _error = null;
        
        var (success, error) = await AuthService.ForgotPasswordAsync(P5Url, _model.Email);
        
        if (success)
        {
            _emailSent = true;
        }
        else
        {
            _error = error;
        }
        
        _loading = false;
    }

    private class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}