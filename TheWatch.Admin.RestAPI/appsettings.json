{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "JwtAuthentication": "Warning",
      "RateLimiting": "Warning"
    }
  },
  "AllowedHosts": "localhost;*.thewatch.app",
  "Jwt": {
    "Key": "TheWatch-P5-AuthSecurity-DevKey-Min32Chars!!",
    "Issuer": "TheWatch.P5.AuthSecurity",
    "Audience": "TheWatch",
    "ClockSkewSeconds": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5001",
      "https://localhost:7001"
    ]
  },
  "RateLimiting": {
    "GlobalPermitLimit": 100,
    "GlobalWindowMinutes": 1,
    "AuthPermitLimit": 10,
    "AuthWindowMinutes": 1
  },
  "ServiceAuth": {
    "ApiKey": "thewatch-service-key-dev"
  }
}
