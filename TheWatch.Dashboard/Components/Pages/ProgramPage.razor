    private record LeaderboardDto(List<LeaderboardEntryDto> Entries, int TotalParticipants);

    private static BadgeStyle GetResponderBadge(string? status) => status switch
    {
        "Available" => BadgeStyle.Success,
        "EnRoute" => BadgeStyle.Info,
        "OnScene" => BadgeStyle.Primary,
        "Busy" => BadgeStyle.Warning,
        "OffDuty" => BadgeStyle.Light,
        _ => BadgeStyle.Light
    };

    private static BadgeStyle GetNodeBadge(string? status) => status switch
    {
        "Online" => BadgeStyle.Success,
        "Relaying" => BadgeStyle.Info,
        "LowBattery" => BadgeStyle.Warning,
        "Offline" => BadgeStyle.Light,
        _ => BadgeStyle.Light
    };

    private static BadgeStyle GetDeviceBadge(string? status) => status switch
    {
        "Connected" => BadgeStyle.Success,
        "Syncing" => BadgeStyle.Info,
        "LowBattery" => BadgeStyle.Warning,
        "Offline" => BadgeStyle.Light,
        "Error" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private static BadgeStyle GetDisasterBadge(string? status) => status switch
    {
        "Declared" => BadgeStyle.Warning,
        "Active" => BadgeStyle.Danger,
        "Contained" => BadgeStyle.Info,
        "Resolved" => BadgeStyle.Success,
        "Archived" => BadgeStyle.Light,
        _ => BadgeStyle.Light
    };
}
