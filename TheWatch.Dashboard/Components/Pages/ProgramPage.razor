    private record ResponderListDto(List<ResponderDto> Items, int TotalCount, int Page, int PageSize);
    private record ProfileDto(Guid Id, string DisplayName, string Email, string? Phone, DateTime CreatedAt);
    private record ProfileListDto(List<ProfileDto> Items, int TotalCount);
