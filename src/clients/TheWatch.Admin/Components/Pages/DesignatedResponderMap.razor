@page "/designated-responders"
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Config
@implements IDisposable

<PageTitle>TheWatch Admin — Designated Responders Map</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="rz-mb-3">
    <RadzenText TextStyle="TextStyle.H4" class="rz-mb-0">
        <RadzenIcon Icon="volunteer_activism" style="vertical-align: middle;" /> Designated Responders
    </RadzenText>
    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@($"{_activeCount} active")" />
    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@($"{_totalCount} total signups")" />
    <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Secondary"
                  Size="ButtonSize.Small" Click="@RefreshAsync" />
    <RadzenButton Text="Fit All" Icon="zoom_out_map" ButtonStyle="ButtonStyle.Light"
                  Size="ButtonSize.Small" Click="@FitAllAsync" />
</RadzenStack>

<!-- Filter -->
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-2">
    <RadzenText TextStyle="TextStyle.Body2">Filter by status:</RadzenText>
    <RadzenDropDown @bind-Value="@_selectedStatus" Data="@_statusOptions" TextProperty="Text" ValueProperty="Value"
                    Placeholder="All statuses" AllowClear="true" Style="width: 180px;"
                    Change="@(_ => RefreshAsync())" />
</RadzenStack>

<!-- Legend -->
<div class="map-legend rz-mb-2">
    <span class="legend-item"><span class="legend-dot" style="background:#2ecc71"></span> Active</span>
    <span class="legend-item"><span class="legend-dot" style="background:#3498db"></span> Approved</span>
    <span class="legend-item"><span class="legend-dot" style="background:#f39c12"></span> Pending</span>
    <span class="legend-item"><span class="legend-dot" style="background:#95a5a6"></span> Inactive</span>
</div>

<!-- Map -->
<div style="height: 500px; border-radius: 8px; overflow: hidden;">
    <WatchMap @ref="_map" Height="100%" CenterLat="39.8283" CenterLng="-98.5795" Zoom="4" />
</div>

<!-- Signup Table with Admin Actions -->
<RadzenText TextStyle="TextStyle.H5" class="rz-mt-4 rz-mb-2">Signup Management</RadzenText>
<RadzenDataGrid Data="@_responders" TItem="DesignatedResponderDto"
                AllowSorting="true" AllowPaging="true" PageSize="10"
                Style="width: 100%;">
    <Columns>
        <RadzenDataGridColumn Property="VolunteerName" Title="Volunteer" Width="160px" />
        <RadzenDataGridColumn Property="Email" Title="Email" Width="200px" />
        <RadzenDataGridColumn Property="Status" Title="Status" Width="120px">
            <Template Context="item">
                <RadzenBadge BadgeStyle="@GetBadgeStyle(item.Status)" Text="@item.Status" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="ResponseRadiusKm" Title="Radius (km)" Width="100px" />
        <RadzenDataGridColumn Property="LocationDescription" Title="Location" Width="180px" />
        <RadzenDataGridColumn Title="Skills" Width="160px">
            <Template Context="item">
                @string.Join(", ", item.Skills)
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Schedule" Width="200px">
            <Template Context="item">
                @string.Join("; ", item.Schedules.Select(s => $"{s.DayOfWeek} {s.StartTime}-{s.EndTime}"))
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Title="Actions" Width="200px" Sortable="false">
            <Template Context="item">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                    @if (item.Status == "Pending")
                    {
                        <RadzenButton Text="Approve" Icon="check" ButtonStyle="ButtonStyle.Success"
                                      Size="ButtonSize.ExtraSmall"
                                      Click="@(() => UpdateStatusAsync(item.Id, "Approved"))" />
                    }
                    @if (item.Status is "Approved" or "Active")
                    {
                        <RadzenButton Text="Deactivate" Icon="block" ButtonStyle="ButtonStyle.Warning"
                                      Size="ButtonSize.ExtraSmall"
                                      Click="@(() => UpdateStatusAsync(item.Id, "Inactive"))" />
                    }
                    <RadzenButton Icon="center_focus_strong" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.ExtraSmall" Click="@(() => FlyToAsync(item))"
                                  title="Zoom to location" />
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private WatchMap? _map;
    private List<DesignatedResponderDto> _responders = [];
    private int _activeCount;
    private int _totalCount;
    private bool _loaded;
    private string? _selectedStatus;

    private readonly List<StatusOption> _statusOptions =
    [
        new("Active", "Active"),
        new("Approved", "Approved"),
        new("Pending", "Pending"),
        new("Inactive", "Inactive"),
        new("Expired", "Expired")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_loaded)
        {
            _loaded = true;
            await Task.Delay(500);
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (_map is null) return;

        try
        {
            var baseUrl = ResolveServiceUrl("p6-firstresponder");
            var client = HttpClientFactory.CreateClient("microservices");

            // Load list for the table
            var listUrl = $"{baseUrl}/api/designated-responders?pageSize=100";
            if (!string.IsNullOrEmpty(_selectedStatus) &&
                Enum.TryParse<DesignatedResponderStatusEnum>(_selectedStatus, out var statusFilter))
            {
                listUrl += $"&status={statusFilter}";
            }
            var listResult = await client.GetFromJsonAsync<DesignatedResponderListResult>(listUrl);

            if (listResult?.Items is not null)
            {
                _responders = listResult.Items;
                _totalCount = listResult.TotalCount;
                _activeCount = _responders.Count(r => r.Status == "Active");

                foreach (var r in _responders)
                {
                    var iconType = r.Status switch
                    {
                        "Active" => "responder-available",
                        "Approved" => "responder-enroute",
                        "Pending" => "responder-busy",
                        _ => "responder-busy"
                    };

                    await _map.AddMarkerAsync(
                        $"dr-{r.Id}", r.Latitude, r.Longitude,
                        iconType, $"{r.VolunteerName} ({r.Status})",
                        $"<b>{r.VolunteerName}</b><br/>Status: {r.Status}<br/>Radius: {r.ResponseRadiusKm} km<br/>{r.LocationDescription ?? ""}");

                    var color = r.Status switch
                    {
                        "Active" => "#2ecc71",
                        "Approved" => "#3498db",
                        "Pending" => "#f39c12",
                        _ => "#95a5a6"
                    };

                    await _map.AddCircleZoneAsync(
                        $"dr-zone-{r.Id}", r.Latitude, r.Longitude,
                        r.ResponseRadiusKm * 1000, color, 0.1);
                }

                if (_responders.Count > 0)
                    await _map.FitAllMarkersAsync(0.15);
            }
        }
        catch { /* P6 offline */ }

        StateHasChanged();
    }

    private async Task UpdateStatusAsync(Guid id, string newStatus)
    {
        try
        {
            var baseUrl = ResolveServiceUrl("p6-firstresponder");
            var client = HttpClientFactory.CreateClient("microservices");
            await client.PutAsJsonAsync($"{baseUrl}/api/designated-responders/{id}/status",
                new { Status = Enum.Parse<DesignatedResponderStatusEnum>(newStatus) });
            await RefreshAsync();
        }
        catch { /* P6 offline */ }
    }

    private async Task RefreshAsync()
    {
        if (_map is null) return;
        await _map.ClearAllAsync();
        await LoadDataAsync();
    }

    private async Task FitAllAsync()
    {
        if (_map is not null)
            await _map.FitAllMarkersAsync(0.15);
    }

    private async Task FlyToAsync(DesignatedResponderDto item)
    {
        if (_map is not null)
            await _map.FlyToAsync(item.Latitude, item.Longitude, 14);
    }

    private string ResolveServiceUrl(string resourceName)
    {
        var httpUrl = Config[$"services:{resourceName}:http:0"];
        if (!string.IsNullOrEmpty(httpUrl)) return httpUrl;
        var httpsUrl = Config[$"services:{resourceName}:https:0"];
        if (!string.IsNullOrEmpty(httpsUrl)) return httpsUrl;
        return $"https+http://{resourceName}";
    }

    private static BadgeStyle GetBadgeStyle(string status) => status switch
    {
        "Active" => BadgeStyle.Success,
        "Approved" => BadgeStyle.Info,
        "Pending" => BadgeStyle.Warning,
        "Inactive" => BadgeStyle.Light,
        "Expired" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    public void Dispose() { }

    // DTOs
    private record DesignatedResponderListResult(List<DesignatedResponderDto> Items, int TotalCount, int Page, int PageSize);
    private record DesignatedResponderDto(
        Guid Id, string VolunteerName, string Email, string? Phone,
        double Latitude, double Longitude, double ResponseRadiusKm,
        string? LocationDescription, string Status,
        List<string> Skills, List<ScheduleDto> Schedules);

    private record ScheduleDto(string DayOfWeek, string StartTime, string EndTime);
    private record StatusOption(string Text, string Value);
    private enum DesignatedResponderStatusEnum { Pending, Approved, Active, Inactive, Expired }
}
