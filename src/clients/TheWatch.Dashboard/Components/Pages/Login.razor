@page "/login"
@inject IConfiguration Config
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject WatchAuthStateProvider AuthState
@inject NotificationService Notification

<PageTitle>TheWatch — Login</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="rz-mt-12">
    <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
        <RadzenCard class="rz-p-6">
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-mb-4">
                <RadzenIcon Icon="shield" style="font-size: 3rem; color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.H4">TheWatch</RadzenText>
            </RadzenStack>

            @if (_isRegistering)
            {
                <RadzenTemplateForm TItem="RegisterModel" Data="@_registerModel" Submit="@OnRegister">
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Display Name" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_registerModel.DisplayName" Name="DisplayName" />
                            <RadzenRequiredValidator Component="DisplayName" Text="Required" />
                        </RadzenFormField>
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_registerModel.Email" Name="RegEmail" />
                            <RadzenRequiredValidator Component="RegEmail" Text="Required" />
                            <RadzenEmailValidator Component="RegEmail" Text="Invalid email" />
                        </RadzenFormField>
                        <RadzenFormField Text="Password" Style="width: 100%;">
                            <RadzenPassword @bind-Value="_registerModel.Password" Name="RegPassword" />
                            <RadzenRequiredValidator Component="RegPassword" Text="Required" />
                        </RadzenFormField>
                        <RadzenFormField Text="Phone (optional)" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_registerModel.Phone" />
                        </RadzenFormField>
                        <RadzenButton Text="Register" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary"
                                      Style="width: 100%;" IsBusy="@_loading" />
                        <RadzenLink Text="Already have an account? Login" @onclick="@(() => _isRegistering = false)"
                                    Style="text-align: center; display: block;" />
                    </RadzenStack>
                </RadzenTemplateForm>
            }
            else
            {
                <RadzenTemplateForm TItem="LoginModel" Data="@_loginModel" Submit="@OnLogin">
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_loginModel.Email" Name="Email" />
                            <RadzenRequiredValidator Component="Email" Text="Required" />
                        </RadzenFormField>
                        <RadzenFormField Text="Password" Style="width: 100%;">
                            <RadzenPassword @bind-Value="_loginModel.Password" Name="Password" />
                            <RadzenRequiredValidator Component="Password" Text="Required" />
                        </RadzenFormField>
                        <RadzenButton Text="Login" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary"
                                      Style="width: 100%;" IsBusy="@_loading" />
                        <RadzenLink Text="Need an account? Register" @onclick="@(() => _isRegistering = true)"
                                    Style="text-align: center; display: block;" />
                    </RadzenStack>
                </RadzenTemplateForm>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Dark" class="rz-mt-2"
                             AllowClose="false">@_error</RadzenAlert>
            }
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private LoginModel _loginModel = new();
    private RegisterModel _registerModel = new();
    private bool _isRegistering;
    private bool _loading;
    private string? _error;

    private async Task OnLogin()
    {
        _loading = true;
        _error = null;
        try
        {
            var p5Url = Config["Services:P5:Url"] ?? "http://localhost:5005";
            var client = HttpClientFactory.CreateClient("microservices");
            var response = await client.PostAsJsonAsync($"{p5Url}/api/auth/login",
                new { _loginModel.Email, _loginModel.Password });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                if (result is not null)
                {
                    await AuthState.LoginAsync(result.AccessToken, result.RefreshToken);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                _error = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach auth service: {ex.Message}";
        }
        _loading = false;
    }

    private async Task OnRegister()
    {
        _loading = true;
        _error = null;
        try
        {
            var p5Url = Config["Services:P5:Url"] ?? "http://localhost:5005";
            var client = HttpClientFactory.CreateClient("microservices");
            var response = await client.PostAsJsonAsync($"{p5Url}/api/auth/register", new
            {
                _registerModel.Email,
                _registerModel.Password,
                _registerModel.DisplayName,
                _registerModel.Phone
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                if (result is not null)
                {
                    await AuthState.LoginAsync(result.AccessToken, result.RefreshToken);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _error = body.Contains("already exists") ? "Email already registered." : "Registration failed.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach auth service: {ex.Message}";
        }
        _loading = false;
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private class RegisterModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string? Phone { get; set; }
    }

    private record LoginResponseDto(string AccessToken, string RefreshToken, DateTime ExpiresAt);
}
