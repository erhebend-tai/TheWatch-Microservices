# TheWatch — Environment Variables (copy to .env and fill in real values)
# NEVER commit the .env file to source control

# SQL Server
SQL_SA_PASSWORD=CHANGE_ME_strong_password_here

# PostgreSQL / PostGIS
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_password_here

# JWT Signing (symmetric — development only)
JWT_SIGNING_KEY=CHANGE_ME_at_least_64_chars_for_hmac_sha256

# JWT Signing (asymmetric — production)
# JWT_ASYMMETRIC_PRIVATE_KEY_PATH=/path/to/private.pem
# JWT_ASYMMETRIC_PUBLIC_KEY_PATH=/path/to/public.pem

# Field Encryption (AES-256)
FIELD_ENCRYPTION_KEY=CHANGE_ME_base64_encoded_32_byte_key

# Log Integrity
LOG_SIGNING_KEY=CHANGE_ME_hmac_signing_key

# Kafka SASL (production)
# KAFKA_SASL_USERNAME=admin
# KAFKA_SASL_PASSWORD=CHANGE_ME

# Docker Registry
# ACR_REGISTRY=thewatch.azurecr.io
